.PHONY: test-prime_2

test-prime_2: prime_2.nix
	@echo "--- Testing prime_2.nix with nix eval ---"
	@nix eval --raw ./prime_2.nix > prime_2.eval.log 2>&1 || { 		echo "ERROR: nix eval failed for prime_2.nix. Check prime_2.eval.log for details."
		cat prime_2.eval.log; 		exit 1; 	}
	@echo "--- prime_2.nix test complete. Output in prime_2.eval.log ---"



